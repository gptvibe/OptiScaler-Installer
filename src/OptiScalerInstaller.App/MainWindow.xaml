<Window x:Class="OptiScalerInstaller.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:OptiScalerInstaller.App.ViewModels"
        mc:Ignorable="d"
        Title="OptiScaler Auto Installer"
        Icon="app.ico"
        Width="1380"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        Background="#101417"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="#F7F5EA" />
            <Setter Property="Background" Value="#24303A" />
            <Setter Property="BorderBrush" Value="#3F515E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,18"
                Padding="20"
                Background="#172027"
                BorderBrush="#2E3942"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Cascadia Code"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#F7F5EA"
                               Text="OptiScaler Auto Installer" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="#A5B7C3"
                               Text="{Binding GpuVendorText}" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="14"
                               Foreground="#7FD1A3"
                               Text="{Binding StatusText}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Content="Refresh Scan" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding BrowseFolderCommand}"
                            Content="Manual Folder" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding InstallSelectedCommand}"
                            Content="Install Selected" />
                    <Button Margin="0"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding InstallAllCommand}"
                            Content="Install All" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1.2*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18"
                        Background="#161E24"
                        BorderBrush="#2E3942"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#F7F5EA"
                                       Text="Detected Games" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="#9CB0BD"
                                       Text="Steam titles are auto-scanned on launch. Manual folders can be added at any time." />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       Foreground="#8196A3"
                                       Text="No supported games found yet."
                                       Visibility="{Binding HasNoGames, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Games}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:DetectedGameItemViewModel}">
                                            <Border Margin="0,0,0,12"
                                                    Padding="14"
                                                    Background="#0E1419"
                                                    BorderBrush="#26323A"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0"
                                                              Margin="0,2,14,0"
                                                              VerticalAlignment="Top"
                                                              IsChecked="{Binding IsSelected}"
                                                              IsEnabled="{Binding CanInstall}" />

                                                    <StackPanel Grid.Column="1">
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#F7F5EA"
                                                                       Text="{Binding DisplayName}" />
                                                            <Border Margin="12,0,0,0"
                                                                    Padding="8,2"
                                                                    Background="#1F2830"
                                                                    CornerRadius="10">
                                                                <TextBlock FontSize="12"
                                                                           Foreground="{Binding StatusBrush}"
                                                                           Text="{Binding StatusText}" />
                                                            </Border>
                                                            <Border Margin="8,0,0,0"
                                                                    Padding="8,2"
                                                                    Background="#24303A"
                                                                    CornerRadius="10">
                                                                <TextBlock FontSize="12"
                                                                           Foreground="#A8C0D0"
                                                                           Text="{Binding SourceLabel}" />
                                                            </Border>
                                                        </DockPanel>

                                                        <TextBlock Margin="0,10,0,0"
                                                                   FontFamily="Cascadia Code"
                                                                   FontSize="12"
                                                                   Foreground="#90A3AF"
                                                                   Text="{Binding InstallPath}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Padding="18"
                        Background="#161E24"
                        BorderBrush="#2E3942"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#F7F5EA"
                                       Text="Installed Records" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="#9CB0BD"
                                       Text="Managed installs can be undone without touching files the app didn’t create." />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding InstalledGames}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:InstallRecordItemViewModel}">
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="#0E1419"
                                                BorderBrush="#26323A"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="#F7F5EA"
                                                               Text="{Binding DisplayName}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="12"
                                                               Foreground="#9CB0BD"
                                                               Text="{Binding Details}" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               FontFamily="Cascadia Code"
                                                               FontSize="11"
                                                               Foreground="#8196A3"
                                                               Text="{Binding InstallPath}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Padding="12,6"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Background="#3A2121"
                                                        BorderBrush="#6E3838"
                                                        BorderThickness="1"
                                                        Command="{Binding DataContext.UndoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Undo"
                                                        Cursor="Hand"
                                                        Foreground="#F7F5EA" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Padding="18"
                    Background="#0B1115"
                    BorderBrush="#2E3942"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock FontFamily="Cascadia Code"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#92F6B8"
                                   Text="terminal.log" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="#7D8F9B"
                                   Text="Live installer output, download steps, warnings, and undo activity." />
                    </StackPanel>

                    <ScrollViewer x:Name="LogScrollViewer"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:LogEntryViewModel}">
                                    <TextBlock Margin="0,0,0,6"
                                               FontFamily="Cascadia Code"
                                               Foreground="{Binding Foreground}"
                                               TextWrapping="Wrap">
                                        <Run Foreground="#5D707D"
                                             Text="[ " />
                                        <Run Foreground="#5D707D"
                                             Text="{Binding Time}" />
                                        <Run Foreground="#5D707D"
                                             Text=" ] " />
                                        <Run Text="{Binding Message}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
